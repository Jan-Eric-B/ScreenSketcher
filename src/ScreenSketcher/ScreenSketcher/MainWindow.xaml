<Window x:Class="ScreenSketcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ScreenSketcher"
        mc:Ignorable="d"
        WindowStyle="None"
        WindowState="Maximized"
        Topmost="True"
        Visibility="Hidden"
        AllowsTransparency="True"
        Background="Transparent">
    <Grid>
        <Border x:Name="mainBorder" BorderBrush="Red" BorderThickness="2" Margin="10" Background="#01FFFFFF">
            <InkCanvas Name="drawingInkCanvas" Background="#01FFFFFF" Focusable="False" Cursor="Pen">
            </InkCanvas>
        </Border>
        <!-- Label to display the integer value -->
        <Label Name="MyLabel" HorizontalAlignment="Right" VerticalAlignment="Top" 
               Background="Transparent" Foreground="Red" Padding="5" Margin="10">
            Scroll Value: 0
        </Label>
    </Grid>
</Window>
